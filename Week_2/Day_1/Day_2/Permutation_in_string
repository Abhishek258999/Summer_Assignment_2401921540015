class Solution {
public:
    bool checkInclusion(string s1, string s2) {
        int n = s1.length();
        int m = s2.length();

        if (n > m) return false;

        int cnt1[26] = {0};
        int cnt2[26] = {0};

        for (char c : s1) {
            cnt1[c - 'a']++;
        }

        for (int i = 0; i < n; i++) {
            cnt2[s2[i] - 'a']++;
        }

        if (equal(cnt1, cnt1 + 26, cnt2))
            return true;

        for (int i = n; i < m; i++) {
            cnt2[s2[i] - 'a']++;
            cnt2[s2[i - n] - 'a']--;

            if (equal(cnt1, cnt1 + 26, cnt2))
                return true;
        }

        return false;
    }
};
